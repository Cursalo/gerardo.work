{
  "rewrites": [
    { "source": "/project/:customLink", "destination": "/index.html" },
    { "source": "/:customLink", "destination": "/index.html" }
  ],
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node",
      "config": {
        "installCommand": "npm install --no-optional"
      }
    }
  ]
} 